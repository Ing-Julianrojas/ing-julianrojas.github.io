---
import Layout from "@/layouts/Layout.astro"

import AboutMe from "@/components/AboutMe.astro"
import Briefcase from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import Experience from "@/components/Experience.astro"
import ProfileCheck from "@/components/icons/ProfileCheck.astro"
import Projects from "@/components/Projects.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import Hero from "@/components/Hero.astro"
import Education from "@/components/Education.astro"
import Contact from "@/components/Contact.astro"
import TitleSection from "@/components/TitleSection.astro"

---

<Layout
  title="Julian Rojas | Desarrollador Full Stack | Software Engineer"
  description="Transformo ideas en aplicaciones web de alto rendimiento. Experto en optimización de código, automatización y protección de infraestructura digital."

>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36">
      <Hero>
    </Hero>
    </SectionContainer>

    <div class="space-y-24">
    <SectionContainer id="experiencia" class="pt-32">
      <TitleSection>
        <Briefcase class="size-8" />
        Experiencia laboral
      </TitleSection>
      <Experience />
    </SectionContainer>

    <SectionContainer id="educacion" class="mb-16">
      <TitleSection>
        <ProfileCheck class="size-8" />
        Educación
      </TitleSection>
      <Education />
    </SectionContainer>

    <SectionContainer id="proyectos">
      <TitleSection>
        <CodeIcon class="size-7" />
        Proyectos
      </TitleSection>
      <Projects />
    </SectionContainer>

    <SectionContainer id="sobre-mi">
      <TitleSection>
        <ProfileCheck class="size-8" />
        Sobre mí
      </TitleSection>
      <AboutMe />
    </SectionContainer>

    <SectionContainer id="contacto">
      <TitleSection>
        <ProfileCheck class="size-8" />
        Contacto
      </TitleSection>
      <Contact />
    </SectionContainer>
  </div>

  </main>
</Layout>
