---
// index.astro - Landing futurista estilo astrov
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Julián Rojas - Desarrollador Full Stack especialista en Soluciones de Software e Inteligencia Artificial con enfoque de Ciberseguridad."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Julián Rojas | Full Stack Developer</title>
    <meta name="darkreader-lock" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Canvas de partículas -->
    <canvas id="particles-canvas"></canvas>

    <!-- Cursor personalizado -->
    <div id="cursor-ring"></div>
    <div id="cursor-dot"></div>

    <!-- Ruido de grano -->
    <div class="grain"></div>

    <!-- Líneas de escaneo -->
    <div class="scanlines"></div>

    <!-- Layout principal -->
    <main class="layout">

      <!-- FOTO + NOMBRE (columna izquierda / centro) -->
      <section class="hero-section" id="hero">

        <!-- Marco de foto estilo HUD -->
        <div class="photo-wrapper" id="photoWrapper">
          <div class="photo-hud-frame">
            <!-- Esquinas animadas -->
            <span class="corner c-tl"></span>
            <span class="corner c-tr"></span>
            <span class="corner c-bl"></span>
            <span class="corner c-br"></span>

            <!-- Líneas de escaneo sobre foto -->
            <div class="photo-scan-line"></div>

            <!-- La foto -->
            <div class="photo-container">
              <img
                src="/juli.jpeg"
                alt="Julián Rojas"
                class="photo"
                id="heroPhoto"
              />
              <!-- Overlay con gradiente futurista -->
              <div class="photo-overlay"></div>
            </div>

            <!-- Badge de estado -->
            <div class="status-badge">
              <span class="status-dot"></span>
              <span class="status-text">DISPONIBLE</span>
            </div>

            <!-- Coordenadas decorativas -->
            <div class="coord coord-top">LAT 4.7110° N</div>
            <div class="coord coord-bottom">LON 74.0721° W</div>
          </div>
        </div>

        <!-- Nombre e info -->
        <div class="hero-info" id="heroInfo">
          <div class="hero-tag">
            <span class="tag-bracket">[</span>
            <span class="tag-text">FULL STACK DEVELOPER</span>
            <span class="tag-bracket">]</span>
          </div>

          <h1 class="hero-name">
            <span class="name-line" id="nameFirst">JULIÁN</span>
            <span class="name-line accent" id="nameLast">ROJAS</span>
          </h1>

          <p class="hero-subtitle">
            // IA · CIBERSEGURIDAD · SOFTWARE
          </p>

          <!-- Links sociales estilo astrov pero futuristas -->
          <div class="social-links">
            <a
              href="https://github.com/Fuckkjulius"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="GitHub"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span>GitHub</span>
            </a>

            <a
              href="https://www.linkedin.com/in/julianrojasgonzalez/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="LinkedIn"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span>LinkedIn</span>
            </a>

            <a
              href="https://instagram.com/fuckkjulius"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="Instagram"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.322a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z"/>
              </svg>
              <span>Instagram</span>
            </a>

            <a
              href="/portafolio#contacto"
              class="social-link cta-link"
              aria-label="Trabajemos juntos"
            >
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              <span>TRABAJEMOS JUNTOS</span>
            </a>
          </div>
        </div>
      </section>

      <!-- NAVEGACIÓN principal estilo astrov -->
      <nav class="main-nav" id="mainNav">
        <a href="/portafolio" class="nav-link" data-text="PORTAFOLIO">
          <span class="nav-num">01</span>
          <span class="nav-label">PORTAFOLIO</span>
          <span class="nav-arrow">→</span>
        </a>
        <a href="/portafolio#proyectos" class="nav-link" data-text="PROYECTOS">
          <span class="nav-num">02</span>
          <span class="nav-label">PROYECTOS</span>
          <span class="nav-arrow">→</span>
        </a>
        <a href="/portafolio#sobre-mi" class="nav-link" data-text="SOBRE MÍ">
          <span class="nav-num">03</span>
          <span class="nav-label">SOBRE MÍ</span>
          <span class="nav-arrow">→</span>
        </a>
        <a href="/portafolio#contacto" class="nav-link" data-text="CONTACTO">
          <span class="nav-num">04</span>
          <span class="nav-label">CONTACTO</span>
          <span class="nav-arrow">→</span>
        </a>
      </nav>

      <!-- Footer con año y firma -->
      <footer class="site-footer">
        <span class="footer-copy">© 2025 JULIÁN ROJAS</span>
        <span class="footer-sep">·</span>
        <span class="footer-code">&lt;/&gt; CON PROPÓSITO</span>
      </footer>
    </main>

    <style is:global>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --neon-cyan: #00f3ff;
        --neon-green: #39ff14;
        --neon-purple: #7c3aed;
        --bg-deep: #060a12;
        --bg-mid: #0d1526;
        --text-primary: #e8edf5;
        --text-muted: #4a5568;
        --text-dim: #2d3748;
      }

      html, body {
        width: 100%;
        height: 100%;
        background: var(--bg-deep);
        color: var(--text-primary);
        overflow: hidden;
        cursor: none;
        font-family: 'Space Grotesk', sans-serif;
      }

      a { text-decoration: none; color: inherit; }

      /* ── CANVAS ── */
      #particles-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      /* ── CURSOR ── */
      #cursor-ring {
        position: fixed;
        width: 36px;
        height: 36px;
        border: 1.5px solid var(--neon-cyan);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transition: width 0.25s ease, height 0.25s ease, border-color 0.25s ease, opacity 0.25s ease;
        transform: translate(-50%, -50%);
        mix-blend-mode: screen;
      }
      #cursor-dot {
        position: fixed;
        width: 5px;
        height: 5px;
        background: var(--neon-cyan);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 8px var(--neon-cyan);
        transition: opacity 0.2s;
      }
      #cursor-ring.is-hovering {
        width: 56px;
        height: 56px;
        border-color: var(--neon-purple);
      }

      /* ── GRAIN ── */
      .grain {
        position: fixed;
        inset: -50%;
        width: 200%;
        height: 200%;
        opacity: 0.028;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
        animation: grain-move 0.4s steps(1) infinite;
        pointer-events: none;
        z-index: 1;
      }
      @keyframes grain-move {
        0%   { transform: translate(0, 0); }
        25%  { transform: translate(-2%, -3%); }
        50%  { transform: translate(3%, 1%); }
        75%  { transform: translate(-1%, 4%); }
        100% { transform: translate(2%, -2%); }
      }

      /* ── SCANLINES ── */
      .scanlines {
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(0, 0, 0, 0.04) 3px,
          rgba(0, 0, 0, 0.04) 4px
        );
        pointer-events: none;
        z-index: 2;
      }

      /* ── LAYOUT ── */
      .layout {
        position: relative;
        z-index: 10;
        min-height: 100dvh;
        display: grid;
        grid-template-rows: 1fr auto auto;
        align-items: center;
        padding: clamp(24px, 5vw, 60px);
        gap: 40px;
      }

      /* ── HERO SECTION ── */
      .hero-section {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(36px, 7vw, 90px);
        flex-wrap: wrap;
      }

      /* ── PHOTO WRAPPER ── */
      .photo-wrapper {
        opacity: 0;
        transform: translateY(20px);
        animation: fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
        flex-shrink: 0;
      }

      .photo-hud-frame {
        position: relative;
        width: clamp(220px, 26vw, 300px);
        height: clamp(300px, 38vw, 440px);
      }

      /* Esquinas HUD */
      .corner {
        position: absolute;
        width: 20px;
        height: 20px;
        z-index: 3;
      }
      .c-tl { top: -2px; left: -2px; border-top: 2px solid var(--neon-cyan); border-left: 2px solid var(--neon-cyan); }
      .c-tr { top: -2px; right: -2px; border-top: 2px solid var(--neon-cyan); border-right: 2px solid var(--neon-cyan); }
      .c-bl { bottom: -2px; left: -2px; border-bottom: 2px solid var(--neon-cyan); border-left: 2px solid var(--neon-cyan); }
      .c-br { bottom: -2px; right: -2px; border-bottom: 2px solid var(--neon-cyan); border-right: 2px solid var(--neon-cyan); }

      /* Marco exterior del frame */
      .photo-hud-frame::before {
        content: '';
        position: absolute;
        inset: -1px;
        border: 1px solid rgba(0, 243, 255, 0.15);
        z-index: 2;
        pointer-events: none;
      }

      /* Contenedor de imagen */
      .photo-container {
        width: 100%;
        height: 100%;
        overflow: hidden;
        position: relative;
      }

      .photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        display: block;
        filter: grayscale(15%) contrast(1.05);
        transition: filter 0.5s ease;
      }

      .photo-hud-frame:hover .photo {
        filter: grayscale(0%) contrast(1.1);
      }

      /* Overlay con color */
      .photo-overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, transparent 50%, rgba(6, 10, 18, 0.8) 100%),
          linear-gradient(135deg, rgba(0, 243, 255, 0.06) 0%, transparent 60%);
        pointer-events: none;
      }

      /* Línea de escaneo animada */
      .photo-scan-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(to right, transparent, var(--neon-cyan), transparent);
        opacity: 0.6;
        animation: scan-down 4s linear infinite;
        z-index: 3;
        pointer-events: none;
      }
      @keyframes scan-down {
        0%   { top: 0%; opacity: 0.6; }
        45%  { opacity: 0.6; }
        50%  { top: 100%; opacity: 0; }
        50.1%{ top: 0%; opacity: 0; }
        55%  { opacity: 0.6; }
        100% { top: 100%; opacity: 0.6; }
      }

      /* Badge de estado */
      .status-badge {
        position: absolute;
        bottom: -12px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 7px;
        background: var(--bg-deep);
        border: 1px solid rgba(57, 255, 20, 0.4);
        padding: 5px 14px;
        z-index: 5;
        white-space: nowrap;
      }
      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--neon-green);
        box-shadow: 0 0 8px var(--neon-green);
        animation: blink 2s ease-in-out infinite;
      }
      @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
      .status-text {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.2em;
        color: var(--neon-green);
      }

      /* Coordenadas */
      .coord {
        position: absolute;
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        z-index: 5;
      }
      .coord-top { top: -22px; right: 0; }
      .coord-bottom { bottom: -22px; left: 0; }

      /* ── HERO INFO ── */
      .hero-info {
        display: flex;
        flex-direction: column;
        gap: 16px;
        max-width: 480px;
        opacity: 0;
        transform: translateX(20px);
        animation: fade-left 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
      }

      .hero-tag {
        display: inline-flex;
        gap: 6px;
        align-items: center;
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        letter-spacing: 0.2em;
        color: var(--neon-cyan);
      }
      .tag-bracket { opacity: 0.5; }

      .hero-name {
        display: flex;
        flex-direction: column;
        line-height: 0.92;
        gap: 0px;
      }
      .name-line {
        font-size: clamp(72px, 11vw, 130px);
        font-weight: 600;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        font-family: 'Space Grotesk', sans-serif;
      }
      .name-line.accent {
        color: transparent;
        -webkit-text-stroke: 1.5px var(--neon-cyan);
        text-shadow: 0 0 60px rgba(0, 243, 255, 0.3);
      }

      .hero-subtitle {
        font-family: 'Space Mono', monospace;
        font-size: 14px;
        letter-spacing: 0.18em;
        color: var(--text-muted);
        margin-top: -4px;
      }

      /* ── SOCIAL LINKS ── */
      .social-links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
      }

      .social-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.12em;
        color: rgba(148, 163, 184, 0.8);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .social-link::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(0, 243, 255, 0.06), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .social-link:hover {
        border-color: rgba(0, 243, 255, 0.4);
        color: var(--neon-cyan);
        box-shadow: 0 0 16px rgba(0, 243, 255, 0.1);
        transform: translateY(-2px);
      }

      .social-link:hover::before { opacity: 1; }
      .social-link svg { flex-shrink: 0; }

      /* Botón CTA destacado */
      .cta-link {
        border-color: rgba(0, 243, 255, 0.35);
        color: var(--neon-cyan);
        background: rgba(0, 243, 255, 0.04);
        box-shadow: 0 0 20px rgba(0, 243, 255, 0.08);
      }
      .cta-link:hover {
        background: rgba(0, 243, 255, 0.12) !important;
        border-color: var(--neon-cyan) !important;
        box-shadow: 0 0 30px rgba(0, 243, 255, 0.2) !important;
        color: #fff !important;
      }

      /* ── MAIN NAV ── */
      .main-nav {
        display: flex;
        gap: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        opacity: 0;
        animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.85s forwards;
      }

      .nav-link {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 20px;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .nav-link:last-child { border-right: none; }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--neon-cyan);
        transform: scaleX(0);
        transition: transform 0.3s ease;
      }

      .nav-link:hover::after { transform: scaleX(1); }

      .nav-link:hover {
        background: rgba(0, 243, 255, 0.03);
      }

      .nav-link:hover .nav-label {
        color: var(--text-primary);
        transform: translateX(4px);
      }

      .nav-link:hover .nav-arrow {
        color: var(--neon-cyan);
        opacity: 1;
        transform: translateX(4px);
      }

      .nav-num {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        color: var(--text-dim);
        letter-spacing: 0.1em;
        flex-shrink: 0;
      }

      .nav-label {
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.18em;
        color: var(--text-muted);
        transition: all 0.3s ease;
        flex: 1;
      }

      .nav-arrow {
        font-size: 14px;
        color: var(--text-dim);
        opacity: 0.5;
        transition: all 0.3s ease;
        margin-left: auto;
      }

      /* ── FOOTER ── */
      .site-footer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 12px 0 4px;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        color: var(--text-dim);
        opacity: 0;
        animation: fade-up 0.6s ease 1.1s forwards;
      }

      /* ── ANIMATIONS ── */
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fade-left {
        from { opacity: 0; transform: translateX(20px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 768px) {
        .layout { grid-template-rows: auto auto auto; padding: 28px 20px; gap: 28px; }
        .hero-section { flex-direction: column; gap: 28px; }
        .hero-info { align-items: center; text-align: center; }
        .social-links { justify-content: center; }
        .main-nav { flex-direction: column; }
        .nav-link { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.05); padding: 14px 16px; }
        .coord { display: none; }
        .status-badge { bottom: -10px; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </body>
</html>

<script>
// ── CURSOR MAGNÉTICO ──
const ring = document.getElementById('cursor-ring') as HTMLDivElement;
const dot  = document.getElementById('cursor-dot')  as HTMLDivElement;
let rX = 0, rY = 0, dX = 0, dY = 0;
let tX = 0, tY = 0;

document.addEventListener('mousemove', (e) => { tX = e.clientX; tY = e.clientY; });

function lerpCursor() {
  dX = tX; dY = tY;
  rX += (tX - rX) * 0.12;
  rY += (tY - rY) * 0.12;
  ring.style.left = rX + 'px';
  ring.style.top  = rY + 'px';
  dot.style.left  = dX + 'px';
  dot.style.top   = dY + 'px';
  requestAnimationFrame(lerpCursor);
}
lerpCursor();

document.querySelectorAll('a, button, .nav-link').forEach(el => {
  el.addEventListener('mouseenter', () => ring.classList.add('is-hovering'));
  el.addEventListener('mouseleave', () => ring.classList.remove('is-hovering'));
});

document.addEventListener('mouseleave', () => { ring.style.opacity = '0'; dot.style.opacity = '0'; });
document.addEventListener('mouseenter', () => { ring.style.opacity = '1'; dot.style.opacity = '1'; });

// ── PARTÍCULAS CON MOUSE REPULSION ──
const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
resize();
window.addEventListener('resize', resize);

interface P { x:number; y:number; vx:number; vy:number; r:number; opacity:number; color:string; }

const COLORS = ['#00f3ff', '#7c3aed', '#39ff14'];
const COUNT = 70;
const CONNECT_DIST = 160;
const MOUSE_REPEL = 120;

const pts: P[] = Array.from({ length: COUNT }, () => ({
  x: Math.random() * window.innerWidth,
  y: Math.random() * window.innerHeight,
  vx: (Math.random() - 0.5) * 0.25,
  vy: (Math.random() - 0.5) * 0.25,
  r: Math.random() * 1.2 + 0.4,
  opacity: Math.random() * 0.6 + 0.3,
  color: COLORS[Math.floor(Math.random() * COLORS.length)],
}));

let mx = -999, my = -999;
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // Actualizar
  for (const p of pts) {
    // Repulsión suave del mouse
    const dx = p.x - mx, dy = p.y - my;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < MOUSE_REPEL && dist > 0) {
      const force = (MOUSE_REPEL - dist) / MOUSE_REPEL * 0.04;
      p.vx += (dx / dist) * force;
      p.vy += (dy / dist) * force;
    }

    p.vx *= 0.992;
    p.vy *= 0.992;

    const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
    if (speed > 1.2) { p.vx *= 1.2 / speed; p.vy *= 1.2 / speed; }

    p.x += p.vx;
    p.y += p.vy;

    if (p.x < 0) { p.x = 0; p.vx *= -1; }
    if (p.x > canvas.width) { p.x = canvas.width; p.vx *= -1; }
    if (p.y < 0) { p.y = 0; p.vy *= -1; }
    if (p.y > canvas.height) { p.y = canvas.height; p.vy *= -1; }
  }

  // Conexiones
  for (let i = 0; i < pts.length; i++) {
    for (let j = i + 1; j < pts.length; j++) {
      const dx = pts[i].x - pts[j].x;
      const dy = pts[i].y - pts[j].y;
      const d = Math.sqrt(dx * dx + dy * dy);
      if (d < CONNECT_DIST) {
        const alpha = (1 - d / CONNECT_DIST) * 0.18;
        ctx.strokeStyle = `rgba(0,243,255,${alpha})`;
        ctx.lineWidth = 0.7;
        ctx.beginPath();
        ctx.moveTo(pts[i].x, pts[i].y);
        ctx.lineTo(pts[j].x, pts[j].y);
        ctx.stroke();
      }
    }
  }

  // Puntos
  for (const p of pts) {
    ctx.shadowColor = p.color;
    ctx.shadowBlur = 8;
    ctx.fillStyle = p.color;
    ctx.globalAlpha = p.opacity;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;
  ctx.shadowBlur = 0;

  requestAnimationFrame(draw);
}
draw();
</script>
