---
import LinkInline from "./LinkInline.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  type?: string
  modality?: string
  challenges?: string[]
  learnings?: string[]
}

const { title, company, description, link, date, type, modality, challenges = [], learnings = [] } = Astro.props
---

<div class="relative mx-4 sm:mx-6 lg:mx-12 pb-12 grid gap-10 md:grid-cols-5 md:gap-10">
  <div class="relative pb-10 md:col-span-2">
    <div class="sticky top-6">
      <span class="text-cyan-400 absolute -left-[42px] rounded-full text-5xl">&bull;</span>

      <h3 class="text-xl font-bold text-cyan-400">{title}</h3>
      <h4 class="font-semibold text-xl text-slate-700 dark:text-white">{company}</h4>
      <time class="p-0 m-0 text-sm text-slate-600 dark:text-white/80">{date}</time>
      {type && <p class="text-xs text-slate-500/70 dark:text-white/60 mt-2">{type}</p>}
      {modality && <p class="text-xs text-slate-500/70 dark:text-white/60">{modality}</p>}
    </div>
  </div>
  <div class="relative flex flex-col gap-6 pb-4 md:col-span-3">
    <p class="text-gray-600 dark:text-gray-300">{description}</p>

    {challenges && challenges.length > 0 && (
      <div class="space-y-3">
        <h4 class="text-sm font-bold text-orange-600 dark:text-orange-400 uppercase tracking-wide">🎯 Desafíos</h4>
        <div class="flex flex-wrap gap-2">
          {challenges.map((challenge) => (
            <span class="px-4 py-2 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 text-sm font-semibold border border-orange-200 dark:border-orange-700/50">
              {challenge}
            </span>
          ))}
        </div>
      </div>
    )}

    {learnings && learnings.length > 0 && (
      <div class="space-y-3">
        <h4 class="text-sm font-bold text-green-600 dark:text-green-400 uppercase tracking-wide">✨ Aprendizajes</h4>
        <div class="flex flex-wrap gap-2">
          {learnings.map((learning) => (
            <span class="px-4 py-2 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-sm font-semibold border border-green-200 dark:border-green-700/50">
              {learning}
            </span>
          ))}
        </div>
      </div>
    )}

    {link && (
      <LinkInline href={link}>
        Saber más{" "}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 icon icon-tabler icon-tabler-chevron-right"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <>
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 6l6 6l-6 6" />
          </>
        </svg>
      </LinkInline>
    )}
  </div>
</div>
