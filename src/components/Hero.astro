---
const personalImageAlt = "Julian Rojas"
---

<section class="relative overflow-hidden pt-24 md:pt-12">
  <!-- Animated Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-gradient-to-r from-blue-400/15 to-purple-400/15 rounded-full blur-3xl animate-pulse hidden sm:block"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-gradient-to-r from-emerald-400/10 to-cyan-400/10 rounded-full blur-3xl animate-pulse hidden md:block" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/3 w-80 h-80 bg-gradient-to-r from-cyan-400/8 to-blue-400/8 rounded-full blur-3xl animate-pulse hidden lg:block" style="animation-delay: 1s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
      <!-- Content -->
      <div class="space-y-6 md:space-y-8">
        <div class="space-y-4 md:space-y-6">
          <div class="inline-flex items-center gap-3 px-3 md:px-4 py-2 rounded-full bg-gradient-to-r from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 border border-slate-200 dark:border-slate-600">
            <div class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></div>
            <span class="text-xs md:text-sm font-medium text-slate-700 dark:text-slate-300">Disponible para proyectos estratégicos</span>
          </div>

          <div class="space-y-3 md:space-y-4">
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold bg-gradient-to-r from-slate-900 via-slate-800 to-slate-700 dark:from-white dark:via-slate-100 dark:to-slate-300 bg-clip-text text-transparent leading-tight">
              Julian Rojas
            </h1>
            <p class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-semibold text-slate-700 dark:text-slate-300">
              Desarrollador Full Stack | Software Engineer
            </p>
          </div>

          <div class="space-y-2 md:space-y-3">
            <p class="text-base md:text-lg leading-relaxed text-slate-600 dark:text-slate-400 max-w-xl">
              <span class="font-semibold text-slate-900 dark:text-white">Desarrollador Full Stack Junior con base sólida en infraestructura y sistemas.</span>
              <span>Construyo aplicaciones web completas — del frontend al backend — y entiendo el entorno de producción donde corren, gracias a mi experiencia en Linux, IAM y soporte de infraestructura híbrida.</span>
            </p>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-start">
          <a href="#contacto" class="inline-flex items-center justify-center rounded-2xl border border-slate-300/80 bg-white/90 px-5 py-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:border-slate-400 hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-950/80 dark:text-slate-100 dark:hover:bg-slate-900">
            Hablemos
          </a>
          <a href="#proyectos" class="inline-flex items-center justify-center rounded-2xl border border-transparent bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-950 dark:hover:bg-slate-200">
            Ver mis proyectos
          </a>
          <div class="inline-flex items-center gap-3">
            <a id="download-cv-es-button" download="Julian-Rojas-CV-ES.pdf" class="cv-button" href="/Julian_Rojas_CV_ES.pdf">
              CV · Español
            </a>
            <a id="download-cv-en-button" download="Julian-Rojas-CV-EN.pdf" class="cv-button cv-outline" href="/Julian_Rojas_CV_EN.pdf">
              CV · Inglés
            </a>
          </div>
        </div>

        <!-- Social Links with sweep effect -->
        <div class="flex flex-wrap gap-3 pt-2 md:pt-4 social-sweep">
          <a href="https://www.linkedin.com/in/julianrojasgonzalez/" target="_blank" rel="noopener" class="group social-btn flex items-center gap-2 rounded-2xl border border-slate-200/70 bg-white/90 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-cyan-500 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100" aria-label="LinkedIn">
            <span>LinkedIn</span>
            <span class="sweep" aria-hidden="true"></span>
          </a>
          <a href="https://github.com/Fuckkjulius" target="_blank" rel="noopener" class="group social-btn flex items-center gap-2 rounded-2xl border border-slate-200/70 bg-white/90 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-slate-900 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100" aria-label="GitHub">
            <span>GitHub</span>
            <span class="sweep" aria-hidden="true"></span>
          </a>
          <a href="https://instagram.com/fuckkjulius" target="_blank" rel="noopener" class="group social-btn flex items-center gap-2 rounded-2xl border border-slate-200/70 bg-white/90 px-3 py-2 text-sm font-medium text-slate-800 transition hover:border-pink-500 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100" aria-label="Instagram">
            <span>Instagram</span>
            <span class="sweep" aria-hidden="true"></span>
          </a>
        </div>
      </div>

      <!-- Profile Image -->
      <div class="relative block">
        <div class="relative mx-auto w-56 h-56 sm:w-72 sm:h-72 md:w-80 md:h-80 lg:w-96 lg:h-96">
          <!-- Decorative background -->
          <div class="absolute inset-0 bg-gradient-to-br from-blue-400/20 via-purple-400/20 to-emerald-400/20 rounded-3xl rotate-6 animate-pulse"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-400/15 to-blue-400/15 rounded-3xl -rotate-3 animate-pulse" style="animation-delay: 1s;"></div>

          <!-- Image container -->
          <div class="relative bg-white dark:bg-slate-800 rounded-3xl p-2 shadow-2xl transform hover:scale-105 transition-transform duration-500">
            <div class="bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-600 rounded-2xl p-1">
              <img
                src="/me.png"
                alt={personalImageAlt}
                class="w-full h-full object-cover rounded-2xl shadow-lg"
              />
            </div>
          </div>

          <!-- Floating elements -->
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-emerald-400 to-cyan-400 rounded-full flex items-center justify-center shadow-lg animate-bounce">
            <span class="text-white font-bold text-lg">🚀</span>
          </div>
          <div class="absolute -bottom-4 -left-4 w-10 h-10 bg-gradient-to-br from-purple-400 to-pink-400 rounded-full flex items-center justify-center shadow-lg animate-bounce" style="animation-delay: 1s;">
            <span class="text-white font-bold text-sm">⚡</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-white via-white/80 to-transparent dark:from-slate-950 dark:via-slate-950/80"></div>
</section>

<style is:global>
  :root { --neon-cyan: #00f3ff; }
  .cv-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.95rem;
    color: #ffffff;
    background: linear-gradient(90deg, rgba(0,243,255,0.08), rgba(124,58,237,0.03));
    border: 2px solid rgba(0,243,255,0.18);
    box-shadow: 0 6px 30px rgba(0,243,255,0.07), inset 0 0 20px rgba(0,243,255,0.02);
    transition: transform 250ms ease, box-shadow 250ms ease, border-color 250ms ease;
    position: relative;
    overflow: hidden;
  }
  .cv-button::after {
    content: '';
    position: absolute;
    left: -40%;
    top: 0;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    transform: skewX(-20deg);
    transition: left 520ms cubic-bezier(.2,.9,.2,1);
    pointer-events: none;
  }
  .cv-button:hover { transform: translateY(-4px) scale(1.02); border-color: var(--neon-cyan); box-shadow: 0 12px 60px rgba(0,243,255,0.14), inset 0 0 40px rgba(0,243,255,0.04); }
  .cv-button:hover::after { left: 120%; }

  .cv-button.cv-outline { color: white; background: transparent; border-color: rgba(255,255,255,0.08); box-shadow: 0 6px 30px rgba(0,0,0,0.35); }
  .cv-button.cv-outline:hover { border-color: var(--neon-cyan); box-shadow: 0 12px 60px rgba(0,243,255,0.08); }
</style>
<style is:global>
  .social-sweep .social-btn { position: relative; overflow: hidden; }
  .social-sweep .sweep {
    position: absolute; left: -60%; top: 0; width: 60%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent); transform: skewX(-18deg); transition: left 520ms cubic-bezier(.2,.9,.2,1); opacity: 0; pointer-events: none;
  }
  .social-sweep .social-btn:hover .sweep { left: 120%; opacity: 1; }
  @media (prefers-color-scheme: dark) { .social-sweep .social-btn { background: rgba(255,255,255,0.02); } }
</style>

