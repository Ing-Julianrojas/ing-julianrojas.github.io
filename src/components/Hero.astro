---
const personalImageAlt = "Julian Rojas"
---

<section class="relative overflow-hidden pt-24 md:pt-12">
  <!-- Animated Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-gradient-to-r from-blue-400/15 to-purple-400/15 rounded-full blur-3xl animate-pulse hidden sm:block"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-gradient-to-r from-emerald-400/10 to-cyan-400/10 rounded-full blur-3xl animate-pulse hidden md:block" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/3 w-80 h-80 bg-gradient-to-r from-cyan-400/8 to-blue-400/8 rounded-full blur-3xl animate-pulse hidden lg:block" style="animation-delay: 1s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
      <!-- Content -->
      <div class="space-y-6 md:space-y-8">
        <div class="space-y-4 md:space-y-6">
          <div class="inline-flex items-center gap-3 px-3 md:px-4 py-2 rounded-full bg-gradient-to-r from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 border border-slate-200 dark:border-slate-600">
            <div class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></div>
            <span class="text-xs md:text-sm font-medium text-slate-700 dark:text-slate-300">Disponible para proyectos estratégicos</span>
          </div>

          <div class="space-y-3 md:space-y-4">
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold bg-gradient-to-r from-slate-900 via-slate-800 to-slate-700 dark:from-white dark:via-slate-100 dark:to-slate-300 bg-clip-text text-transparent leading-tight">
              Julian Rojas
            </h1>
            <p class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-semibold text-slate-700 dark:text-slate-300">
              Desarrollador Full Stack | Software Engineer
            </p>
          </div>

          <div class="space-y-2 md:space-y-3">
            <p class="text-base md:text-lg leading-relaxed text-slate-600 dark:text-slate-400 max-w-xl">
              <span class="font-semibold text-slate-900 dark:text-white">Transformo ideas en aplicaciones web de alto rendimiento.</span> Experto en optimización de código, automatización y protección de infraestructura digital.
            </p>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 md:gap-4">
          <a href="#contacto" class="inline-flex items-center justify-center px-6 md:px-8 py-3 md:py-4 border-2 border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 font-semibold text-sm md:text-base rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all duration-300 transform hover:scale-105 w-full sm:w-auto">
            Hablemos
          </a>
          <a href="#proyectos" class="group relative inline-flex items-center justify-center px-6 md:px-8 py-3 md:py-4 bg-gradient-to-r from-slate-900 to-slate-800 hover:from-slate-800 hover:to-slate-700 text-white font-semibold text-sm md:text-base rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-2xl w-full sm:w-auto">
            <span class="relative z-10">Ver mis proyectos</span>
            <div class="absolute inset-0 bg-gradient-to-r from-slate-800 to-slate-700 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex gap-3 md:gap-4 pt-2 md:pt-4">
          <a href="https://www.linkedin.com/in/julianrojasgonzalez/" target="_blank" rel="noopener" class="group p-2 md:p-3 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 transform hover:scale-110 hover:shadow-lg" title="LinkedIn">
            <svg class="w-5 md:w-6 h-5 md:h-6 text-slate-700 dark:text-slate-300 group-hover:text-blue-600 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227 .792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://github.com/Fuckkjulius" target="_blank" rel="noopener" class="group p-2 md:p-3 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 transform hover:scale-110 hover:shadow-lg" title="GitHub">
            <svg class="w-5 md:w-6 h-5 md:h-6 text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729 .083-.729 1.205 .084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492 .997 .107-.775 .418-1.305 .762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311 .469-2.381 1.236-3.221-.124-.303-.535-1.524 .117-3.176 0 0 1.008-.322 3.301 1.23 .957-.266 1.983-.399 3.003-.404 1.02 .005 2.047 .138 3.006 .404 2.291-1.552 3.297-1.23 3.297-1.23 .653 1.653 .242 2.874 .118 3.176 .77 .84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921 .43 .372 .823 1.102 .823 2.222v3.293c0 .319 .192 .694 .801 .576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://instagram.com/fuckkjulius" target="_blank" rel="noopener" class="group p-2 md:p-3 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 transform hover:scale-110 hover:shadow-lg" title="Instagram">
            <svg class="w-5 md:w-6 h-5 md:h-6 text-slate-700 dark:text-slate-300 group-hover:text-pink-600 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.322a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Profile Image -->
      <div class="relative hidden lg:block">
        <div class="relative mx-auto w-80 h-80 lg:w-96 lg:h-96">
          <!-- Decorative background -->
          <div class="absolute inset-0 bg-gradient-to-br from-blue-400/20 via-purple-400/20 to-emerald-400/20 rounded-3xl rotate-6 animate-pulse"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-400/15 to-blue-400/15 rounded-3xl -rotate-3 animate-pulse" style="animation-delay: 1s;"></div>

          <!-- Image container -->
          <div class="relative bg-white dark:bg-slate-800 rounded-3xl p-2 shadow-2xl transform hover:scale-105 transition-transform duration-500">
            <div class="bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-600 rounded-2xl p-1">
              <img
                src="/me.png"
                alt={personalImageAlt}
                class="w-full h-full object-cover rounded-2xl shadow-lg"
              />
            </div>
          </div>

          <!-- Floating elements -->
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-emerald-400 to-cyan-400 rounded-full flex items-center justify-center shadow-lg animate-bounce">
            <span class="text-white font-bold text-lg">🚀</span>
          </div>
          <div class="absolute -bottom-4 -left-4 w-10 h-10 bg-gradient-to-br from-purple-400 to-pink-400 rounded-full flex items-center justify-center shadow-lg animate-bounce" style="animation-delay: 1s;">
            <span class="text-white font-bold text-sm">⚡</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-white via-white/80 to-transparent dark:from-slate-950 dark:via-slate-950/80"></div>
</section>

