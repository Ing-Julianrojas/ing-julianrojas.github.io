---
import ThemeToggle from "./ThemeToggle.astro"

// Detectar la página actual
const currentPath = new URL(Astro.request.url).pathname;
const isPortfolio = currentPath.includes('/portafolio');

const navItems = [
  {
    title: "Experiencia",
    url: isPortfolio ? "/portafolio#experiencia" : "/#experiencia",
  },
  {
    title: "Educación",
    url: isPortfolio ? "/portafolio#educacion" : "/#educacion",
  },
  {
    title: "Proyectos",
    url: isPortfolio ? "/portafolio#proyectos" : "/#proyectos",
  },
  {
    title: "Sobre mí",
    url: isPortfolio ? "/portafolio#sobre-mi" : "/#sobre-mi",
  },
  {
    title: "Contacto",
    url: isPortfolio ? "/portafolio#contacto" : "/#contacto",
  },
]
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-slate-200/70 bg-white/90 shadow-sm backdrop-blur-xl dark:border-slate-800/70 dark:bg-slate-950/90">
  <div class="mx-auto flex h-14 w-full max-w-7xl items-center justify-between px-3 md:px-6">
    <nav class="relative flex w-full items-center justify-center">
      <div class="flex w-full min-w-0 items-center justify-center gap-2">
        <!-- Desktop nav (hidden on small screens) -->
        <div class="hidden md:block">
          <div class="flex items-center gap-1 rounded-full border border-slate-200/80 bg-white/85 px-1 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-slate-700 shadow-sm backdrop-blur-xl dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200">
            <a href="/" aria-label="Inicio" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-transparent text-slate-700 transition hover:border-cyan-400 hover:text-cyan-500 dark:text-slate-200">
              <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/></svg>
            </a>
            <div id="desktop-nav" class="flex min-w-0 items-center justify-center gap-1">
              {
                navItems.map((link) => (
                  <a
                    class="flex-shrink-0 whitespace-nowrap rounded-full px-2.5 py-1.5 text-[0.72rem] uppercase tracking-[0.18em] transition text-slate-700 dark:text-slate-200 hover:text-cyan-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500"
                    href={link.url}
                  >
                    {link.title}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Mobile: home + hamburger -->
        <div class="md:hidden flex w-full items-center justify-start gap-2">
          <a href="/" aria-label="Inicio" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white/90 text-slate-700 shadow-sm hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/></svg>
          </a>
          <button id="menu-toggle" aria-expanded="false" aria-controls="mobile-nav" class="inline-flex items-center justify-center h-9 w-9 rounded-full border border-slate-200 bg-white/90 text-slate-700 shadow-sm hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>

      <div class="relative ml-2 md:absolute md:right-6 flex items-center gap-2">
        <div class="hidden md:block"><ThemeToggle /></div>
        <div class="md:hidden">
          <!-- keep theme toggle visible in mobile inside header right area -->
          <ThemeToggle />
        </div>
      </div>

      <!-- Mobile nav overlay (full-screen) -->
      <div id="mobile-nav" class="hidden md:hidden fixed inset-0 z-50 bg-black/40 backdrop-blur-sm">
        <div class="absolute inset-0 flex items-start justify-center">
          <div class="w-full max-w-md mx-4 mt-20 bg-white/95 dark:bg-slate-950/95 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-2xl">
            <div class="relative">
              <button id="menu-close" aria-label="Cerrar menú" class="absolute right-3 top-3 p-2 rounded-md text-slate-700 dark:text-slate-200">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
              <div class="mobile-scan-line" aria-hidden="true"></div>
              <div class="flex flex-col py-6 px-4">
                <a href="/" class="nav-link-mobile mb-2 rounded-lg px-4 py-3 text-slate-800 dark:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-900" data-mobile-link style="--i:0">
                  Inicio
                </a>
                {
                  navItems.map((link, i) => (
                    <a href={link.url} class="nav-link-mobile rounded-lg px-4 py-3 text-slate-800 dark:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-900" data-mobile-link style={`--i:${i + 1}`}>
                      {link.title}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const sections = document.querySelectorAll<HTMLElement>('section[id]');
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('#desktop-nav a');

      const updateActive = (id: string | null) => {
        navLinks.forEach((item) => {
          const href = item.getAttribute('href');
          const isActive = href === `/#${id}` || href === `/portafolio#${id}` || href === `#${id}`;
          item.classList.toggle('text-blue-500', isActive);
        });
      };

      const callback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            updateActive(entry.target.id);
          }
        });
      };

      const observer = new IntersectionObserver(callback, {
        root: null,
        rootMargin: '-40% 0px -55% 0px',
        threshold: 0.25,
      });

      if (sections.length > 0) {
        sections.forEach((section) => observer.observe(section));
      }

      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') {
          observer.disconnect();
        } else {
          sections.forEach((section) => observer.observe(section));
        }
      });
      // Mobile menu toggle
      const menuToggle = document.getElementById('menu-toggle')
      const mobileNav = document.getElementById('mobile-nav')
      if (menuToggle && mobileNav) {
        const setOpen = (open: boolean) => {
          menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false')
          if (open) {
            mobileNav.classList.remove('hidden')
            mobileNav.classList.add('open')
            document.body.style.overflow = 'hidden'
          } else {
            mobileNav.classList.remove('open')
            mobileNav.classList.add('hidden')
            document.body.style.overflow = ''
          }
        }

        menuToggle.addEventListener('click', (e) => {
          e.stopPropagation()
          const isOpen = menuToggle.getAttribute('aria-expanded') === 'true'
          setOpen(!isOpen)
        })

        document.addEventListener('click', (event) => {
          if (!mobileNav.classList.contains('hidden')) {
            const target = event.target
            if (!(target instanceof HTMLElement)) return
            if (!target.closest('#mobile-nav') && !target.closest('#menu-toggle')) {
              setOpen(false)
            }
          }
        })

        // Close button inside overlay
        const menuClose = document.getElementById('menu-close')
        if (menuClose) menuClose.addEventListener('click', () => setOpen(false))

        // Close menu when a mobile link is clicked
        mobileNav.querySelectorAll('[data-mobile-link]').forEach((el) => {
          el.addEventListener('click', () => setOpen(false))
        })
      }
    });
  </script>
  <style is:global>
    /* Mobile menu overlay and animations */
    #mobile-nav { z-index: 60; }
    #mobile-nav { display: none; }
    #mobile-nav.open { display: block; }
    #mobile-nav { transition: opacity 220ms ease; }
    #mobile-nav .mobile-scan-line {
      position: absolute;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, rgba(0,243,255,0.95), transparent);
      top: 0;
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
    }
    #mobile-nav.open .mobile-scan-line {
      animation: mobile-scan 1.6s linear infinite;
      transform: translateY(0%);
      opacity: 0.9;
    }
    @keyframes mobile-scan {
      0% { transform: translateY(-6%); opacity: 0; }
      20% { opacity: 0.9; }
      50% { transform: translateY(100%); opacity: 0; }
      100% { transform: translateY(200%); opacity: 0; }
    }

    .nav-link-mobile {
      transform: translateX(-6px);
      opacity: 0;
      transition: transform 320ms cubic-bezier(.2,.9,.2,1), opacity 320ms cubic-bezier(.2,.9,.2,1);
    }
    #mobile-nav.open .nav-link-mobile {
      transform: translateX(0);
      opacity: 1;
    }
    /* stagger via custom property set inline */
    .nav-link-mobile { transition-delay: calc(var(--i) * 60ms); }

    /* small polish: darker bg in dark mode */
    @media (prefers-color-scheme: dark) {
      #mobile-nav { background: rgba(8,10,15,0.96); }
    }
    @media (max-width: 768px) {
      #mobile-nav { background: rgba(0,0,0,0.35); }
      #mobile-nav > .absolute > .max-w-md { transform: translateY(0); }
    }
  </style>
</header>
