---
import ThemeToggle from "./ThemeToggle.astro"

// Detectar la página actual
const currentPath = new URL(Astro.request.url).pathname;
const isPortfolio = currentPath.includes('/portafolio');

const navItems = [
  {
    title: "Experiencia",
    label: "experiencia",
    url: isPortfolio ? "/portafolio#experiencia" : "/#experiencia",
  },
  {
    title: "Educación",
    label: "educacion",
    url: isPortfolio ? "/portafolio#educacion" : "/#educacion",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: isPortfolio ? "/portafolio#proyectos" : "/#proyectos",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: isPortfolio ? "/portafolio#sobre-mi" : "/#sobre-mi",
  },
  {
    title: "Contacto",
    label: "contacto",
    url: isPortfolio ? "/portafolio#contacto" : "/#contacto",
  },
]
---

<header
  class="fixed top-0 z-50 flex items-center justify-between w-full px-4 md:px-0 md:justify-center py-4 md:mt-2"
>
  <!-- Mobile Menu Button -->
  <button
    id="mobile-menu-btn"
    class="md:hidden flex flex-col gap-1.5 p-2"
    aria-label="Abrir menú"
  >
    <span class="w-6 h-0.5 bg-gray-600 dark:bg-gray-200 transition-all"></span>
    <span class="w-6 h-0.5 bg-gray-600 dark:bg-gray-200 transition-all"></span>
    <span class="w-6 h-0.5 bg-gray-600 dark:bg-gray-200 transition-all"></span>
  </button>

  <!-- Desktop Navigation -->
  <nav
    class="hidden md:flex px-3 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200 justify-center items-center gap-1 bg-white/50 dark:bg-slate-900/50 backdrop-blur-md border border-gray-200 dark:border-gray-700"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-3 py-2 transition hover:text-blue-500 dark:hover:text-blue-500"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>

  <!-- Mobile Navigation Menu -->
  <nav
    id="mobile-menu"
    class="hidden absolute top-16 left-0 right-0 md:hidden flex flex-col gap-2 px-4 py-4 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md border-b border-gray-200 dark:border-gray-700"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-4 py-3 transition hover:text-blue-500 dark:hover:text-blue-500 text-gray-600 dark:text-gray-200"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <div class="px-4 py-2">
      <ThemeToggle />
    </div>
  </nav>

  <!-- Desktop Theme Toggle -->
  <div class="hidden md:block">
    <ThemeToggle />
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = mobileMenu?.querySelectorAll('a');

    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Close menu when clicking a link
      mobileLinks?.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
        });
      });
    }

    // Existing intersection observer code
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a:not(#mobile-menu a)")

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-blue-500")
            } else {
              item.classList.remove("text-blue-500")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })
  });
</script>

    sections.forEach((section) => {
      observer.observe(section)
    })

    // Cleanup function
    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  nav {
    @apply dark:bg-gray-800/90 bg-white/50;
  }

  @keyframes nav-shadown {
    0% {
      @apply dark:bg-gray-800/0 bg-white/0;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur ring-white/10;
    }
  }
</style>
